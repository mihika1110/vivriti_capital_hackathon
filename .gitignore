# Add content to .gitignore
@"
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual Environment
venv/
env/
ENV/
venv.bak/
env.bak/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Uploads
uploads/*
!uploads/.gitkeep

# Data files (add if you DON'T want to track CSV files)
# *.csv
# *.xlsx
# *.xls

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Logs
*.log

# Jupyter Notebook
.ipynb_checkpoints

# pytest
.pytest_cache/
"@ | Out-File -FilePath .gitignore -Encoding utf8